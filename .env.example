# Copy this file to .env and fill in keys to enable real AI generation.
# Never commit .env — credentials stay local only.
#
# Location: <project-root>/.env
# After editing, restart Streamlit:
#   streamlit run app.py

# --- Required to leave Demo Mode ---
OPENAI_API_KEY=

# --- Other LLM providers ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OLLAMA_HOST=
LOCAL_LLM_ENDPOINT=

# --- Image providers ---
BFL_API_KEY=
IDEOGRAM_API_KEY=
STABILITY_API_KEY=

# --- Video providers ---
RUNWAY_API_KEY=
PIKA_API_KEY=
KLING_API_KEY=
LUMA_API_KEY=

# --- Audio providers (ElevenLabs) ---
# Get a key at https://elevenlabs.io — store ONLY in local .env (never commit)
ELEVENLABS_API_KEY=
# Permanent default (VOICE_ASSET_0001 Founder Voice) — cloned voice ID, not the API key
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_VOICE_FOUNDER=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_REQUEST_TIMEOUT=90
ELEVENLABS_MAX_RETRIES=2
# Failover: 0 = never silently replace Founder Voice (recommended)
ELEVENLABS_ALLOW_FALLBACK=0
# Optional per-narrator voice overrides (ElevenLabs voice IDs — Voice Studio)
# Or edit data/voice_studio/PROFILE_VOICES.json (no voice IDs in source code)
# ELEVENLABS_VOICE_PROFESSOR=
# ELEVENLABS_VOICE_DOCUMENTARY=
# ELEVENLABS_VOICE_STORYTELLER=
# ELEVENLABS_VOICE_SCIENCE=
# ELEVENLABS_VOICE_TECH=
# ELEVENLABS_VOICE_HISTORY=
# ELEVENLABS_VOICE_CALM=
# ELEVENLABS_VOICE_ENERGETIC=
# ELEVENLABS_USE_SDK=1

# --- Music (future abstraction) ---
MUSIC_PROVIDER_API_KEY=
MUSIC_PROVIDER_ENDPOINT=

# --- Platform / multi-model ---
REPLICATE_API_TOKEN=
FAL_KEY=

# --- Google News RSS (no API key; optional tuning) ---
# GOOGLE_NEWS_REFRESH_SEC=900
# GOOGLE_NEWS_MAX_AGE_HOURS=48
# GOOGLE_NEWS_ENGLISH_ONLY=1

# --- Publishing (OAuth / access tokens) ---
YOUTUBE_API_KEY=
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_AUTHOR_URN=

# --- Local / self-hosted ---
COMFYUI_ENDPOINT=
LOCAL_DIFFUSION_ENDPOINT=

# --- Optional runtime config / secrets ---
# PROVIDER_CONFIG_PATH=data/provider_runtime/config.json
# PROVIDER_SECRETS_PATH=data/provider_runtime/secrets.enc.json
# PROVIDER_SECRETS_PASSPHRASE=
