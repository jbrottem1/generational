      "jaw_stabilize": 0.4
    },
    "compassion": {
      "eye_soften": 0.65,
      "inner_brow_raise": 0.2,
      "lip_corner_raise": 0.2
    },
    "curiosity": {
      "brow_inner_raise": 0.35,
      "head_tilt": 0.25,
