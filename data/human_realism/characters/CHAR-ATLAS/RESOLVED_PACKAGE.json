      "elbows",
      "waist",
      "hips",
      "knees",
      "wrists",
      "seated_contact"
    ],
    "forbid": [
      "frozen_fabric",
      "fabric_leads_body",
      "identical_motion_all_garments",
      "limb_clipping"
    ],
    "default_material": {
      "thickness": "medium",
      "weight": "medium",
      "stiffness": "controlled_drape",
      "stretch": "low",
      "damping": "medium",
      "wind_response": "moderate"
